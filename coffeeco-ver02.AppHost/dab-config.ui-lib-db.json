{
  "$schema": "https://github.com/Azure/data-api-builder/releases/download/v1.7.90/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "connection-string": "@env('ConnectionStrings__ui-lib-db')",
    "options": {
      "set-session-context": false
    }
  },
  "runtime": {
    "rest": {
      "enabled": true,
      "path": "/api",
      "request-body-strict": true
    },
    "graphql": {
      "enabled": true,
      "path": "/graphql",
      "allow-introspection": true
    },
    "health": {
      "enabled": true,
      "cache-ttl-seconds": 5,
      "roles": [
        "anonymous"
      ],
      "max-query-parallelism": 4
    }
  },
  "entities": {
    "HomeContent": {
      "source": {
        "object": "HomeContents",
        "type": "table"
      },
      "fields": [],
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "HomeContent",
          "plural": "HomeContents"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "Anonymous",
          "actions": [
            {
              "action": "read",
              "fields": {
                "exclude": [],
                "include": [
                  "Id"
                ]
              }
            }
          ]
        }
      ],
      "relationships": {
        "HomeRows": {
          "cardinality": "many",
          "target.entity": "HomeRow",
          "source.fields": [],
          "target.fields": [],
          "linking.source.fields": [],
          "linking.target.fields": []
        }
      }
    },
    "HomeRow": {
      "source": {
        "object": "HomeRows",
        "type": "table"
      },
      "fields": [],
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "HomeRow",
          "plural": "HomeRows"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "Anonymous",
          "actions": [
            {
              "action": "read",
              "fields": {
                "exclude": [],
                "include": [
                  "Id",
                  "HomeContentId",
                  "HomeRowTypeId"
                ]
              }
            }
          ]
        }
      ],
      "relationships": {
        "HomeItems": {
          "cardinality": "many",
          "target.entity": "HomeItem",
          "source.fields": [],
          "target.fields": [],
          "linking.source.fields": [],
          "linking.target.fields": []
        }
      }
    },
    "HomeItem": {
      "source": {
        "object": "HomeItems",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "HomeItem",
          "plural": "HomeItems"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "Anonymous",
          "actions": [
            {
              "action": "read",
              "fields": {
                "exclude": [],
                "include": [
                  "Id",
                  "Text",
                  "HomeRowId",
                  "HomeItemTypeId"
                ]
              }
            }
          ]
        }
      ]
    },
    "HomeItemType": {
      "source": {
        "object": "HomeItemTypes",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "HomeItemType",
          "plural": "HomeItemTypes"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "Anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    },
    "HomeRowType": {
      "source": {
        "object": "HomeRowTypes",
        "type": "table"
      },
      "graphql": {
        "enabled": true,
        "type": {
          "singular": "HomeRowType",
          "plural": "HomeRowTypes"
        }
      },
      "rest": {
        "enabled": true
      },
      "permissions": [
        {
          "role": "Anonymous",
          "actions": [
            {
              "action": "read"
            }
          ]
        }
      ]
    }
  }
}